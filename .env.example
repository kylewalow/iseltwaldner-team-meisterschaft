# Admin panel Basic Auth (required in production)
ADMIN_USER=admin
ADMIN_PW=change-me

# Vercel KV / Upstash Redis REST credentials.
# Set automatically by the Vercel KV (Upstash) integration in the dashboard.
# For local development against a real KV instance, set them here.
# If both are missing, the app falls back to an in-memory store (dev only).
KV_REST_API_URL=
KV_REST_API_TOKEN=
